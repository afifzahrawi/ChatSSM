{
  "_readme": [
    "ChatSSM Knowledge Base Configuration",
    "──────────────────────────────────────────────────────────────────────",
    "HOW TO ADD A NEW SOURCE:",
    "  1. Add an entry to the 'sources' array below.",
    "  2. Set the correct 'doc_type' (see reference below).",
    "  3. Run:  python preprocess.py --key <your_key>",
    "  4. Restart the app (or click Reload Config in the sidebar).",
    "",
    "FIELD REFERENCE:",
    "  key        - unique identifier, lowercase + underscores only",
    "  name       - human-readable display name shown in the UI",
    "  category   - Legislations | Practice Notes | Practice Directives |",
    "               Guidelines | Circular | FAQ | Forms",
    "  type       - pdf  OR  csv",
    "  doc_type   - which PARSER to use:",
    "               act         = Malaysian Acts (PART / Section structure)",
    "               regulation  = Malaysian Regulations (numbered paragraph structure)",
    "               general     = Practice Notes, Guidelines, Circulars (numbered paragraphs, headings, free prose)",
    "               faq         = FAQ documents (Q: / A: pairs or numbered Q&A)",
    "               others      = For any other document types. Uses general parsing with AI cleanup.",
    "  url        - (pdf) public download URL",
    "  local_path - (pdf or csv) absolute path on your machine",
    "  enabled    - true = skip this source entirely"
  ],

